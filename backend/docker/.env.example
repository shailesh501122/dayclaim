# Copy to .env and fill in real values before running `docker compose up`.
# Never commit the real .env — it holds secrets. In AWS these come from
# Secrets Manager / KMS instead of a flat file (see docs/SECURITY.md).

POSTGRES_USER=ascent_ar
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=change-me

RABBITMQ_USER=ascent_ar
RABBITMQ_PASSWORD=change-me

# openssl rand -base64 48
JWT_SIGNING_KEY=change-me-to-a-random-32-byte-or-longer-string
JWT_ISSUER=ascent-ar-api
JWT_AUDIENCE=ascent-ar-clients

# openssl rand -base64 32   (must decode to exactly 32 bytes each, and must differ from one another)
ENCRYPTION_DATA_KEY=change-me-base64-32-bytes
ENCRYPTION_BLIND_INDEX_KEY=change-me-base64-32-bytes

# Origin of the React frontend allowed to call the API via CORS.
FRONTEND_ORIGIN=http://localhost:5173

ASPNETCORE_ENVIRONMENT=Development
